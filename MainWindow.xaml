<Window x:Class="SystemControlApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Control Panel"
        Width="400"
        Height="460"
        WindowStartupLocation="CenterScreen"
        ShowActivated="False"
        Topmost="False">

	<StackPanel Margin="20" VerticalAlignment="Center">

		<!-- Volume -->
		<TextBlock Text="Master Volume"
                   FontSize="16"
                   Margin="0,0,0,5"/>

		<Slider x:Name="VolumeSlider"
                Minimum="0"
                Maximum="100"
                Margin="0,0,0,20"
                ValueChanged="VolumeSlider_ValueChanged"/>

		<!-- Brightness -->
		<TextBlock Text="Brightness"
                   FontSize="16"
                   Margin="0,0,0,5"/>

		<Slider x:Name="BrightnessSlider"
                Minimum="0"
                Maximum="100"
                Margin="0,0,0,20"
                ValueChanged="BrightnessSlider_ValueChanged"/>

		<!-- Internet Status -->
		<TextBlock x:Name="InternetStatusText"
                   Text="Internet: Checking..."
                   FontSize="14"
                   Margin="0,10,0,10"
                   Foreground="Gray"/>

		<Button Content="Check Internet"
                Height="32"
                Margin="0,5,0,10"
                Click="CheckInternet_Click"/>

		<!-- Action Buttons Grid -->
		<Grid Margin="0,10,0,0">

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- Row 1 -->
			<Button Grid.Row="0" Grid.Column="0"
                    Content="Restart"
                    Height="38"
                    Margin="5"
                    Click="Restart_Click"/>

			<Button Grid.Row="0" Grid.Column="1"
                    Content="Sleep"
                    Height="38"
                    Margin="5"
                    Click="Sleep_Click"/>

			<Button Grid.Row="0" Grid.Column="2"
                    Content="Shutdown"
                    Height="38"
                    Margin="5"
                    Click="Shutdown_Click"/>

			<!-- Row 2 -->
			<Button Grid.Row="1" Grid.Column="0"
                    Content="Rotate Screen"
                    Height="38"
                    Margin="5"
                    Click="RotateScreen_Click"/>

			<Button Grid.Row="1" Grid.Column="1"
                    Content="Capture Screen"
                    Height="38"
                    Margin="5"
                    Click="CaptureScreen_Click"/>

			<Button Grid.Row="1" Grid.Column="2"
                    Content="Launch App"
                    Height="38"
                    Margin="5"
                    Click="LaunchApp_Click"/>

			<!-- Row 3 (USB Control added here) -->
			<Button Grid.Row="2" Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Content="Toggle USB Enable/Disable"
                    Height="40"
                    Margin="5"
                    Click="ToggleUSB_Click"/>
			<Button Grid.Row="3" Grid.Column="0"
					Grid.ColumnSpan="3"
                    Content="Check Update and Download"
                    Height="40"
                    Margin="5"
                    Click="CheckUpdate_Click"/>

		</Grid>

		<!-- Crash List -->
		<ListBox x:Name="CrashList"
                 Height="180"
                 Margin="0,10,0,10"/>

	</StackPanel>
</Window>